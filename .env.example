# Skopiuj ten plik do .env i uzupełnij wartości PRZED uruchomieniem docker-compose up
# Nigdy nie commituj pliku .env do repozytorium!

# Hasło do bazy danych PostgreSQL
POSTGRES_PASSWORD=changeme_strong_password_here

# Klucz podpisywania tokenów JWT — min. 32 losowych znaków
# Przykład generowania: openssl rand -base64 48
JWT_KEY=changeme_replace_with_at_least_32_random_chars

# MinIO — storage zdjęć protokołów
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_strong_password_here

# Dozwolony origin frontendu (CORS)
CORS_ALLOWED_ORIGIN=http://localhost:5173
